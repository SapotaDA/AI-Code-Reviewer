# Database (use a local PostgreSQL or Neon for testing)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_code_reviewer?schema=public"

# JWT (use a strong secret in production)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-123456789"
JWT_EXPIRES_IN="7d"

# AI Service (get your key from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY="your-gemini-api-key-here"

# Server
PORT=5000
NODE_ENV="development"

# Frontend
FRONTEND_URL="http://localhost:3000"
